name: Build PDF

on: [push]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3

      - uses: xu-cheng/latex-action@v2
        with:
          root_file: main.tex

      - uses: actions/upload-artifact@v3
        with:
          name: pdf
          path: main.pdf
